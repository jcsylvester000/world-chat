"use client";

import { useEffect, useState } from "react";
import dynamic from "next/dynamic";
import Link from "next/link";
import { useParams, useRouter } from "next/navigation";
import Avatar from "@/components/ui/Avatar";
import Badge from "@/components/ui/Badge";
import Spinner from "@/components/ui/Spinner";
import PropertyTags from "@/components/PropertyTags";
import AttachmentModal from "@/components/AttachmentModal";
import RequestModal from "@/components/RequestModal";
import DocumentModal from "@/components/DocumentModal";
import { useAuthStore } from "@/lib/store/auth-store";
import { useChatStore } from "@/lib/store/chat-store";
import { findProfileById, findVisiblePropertyById, getRequest, hasAccess } from "@/lib/data/services";
import { displayName, formatPeso, formatDate } from "@/lib/utils";
import FavoriteButton from "@/components/FavoriteButton";
import type { Profile, Property, PropertyRequest } from "@/lib/types";

const PropertyMap = dynamic(() => import("@/components/PropertyMap"), {
  ssr: false,
  loading: () => <div className="h-full w-full bg-slate-100" />,
});

export default function PropertyDetailPage() {
  const { id } = useParams<{ id: string }>();
  const router = useRouter();
  const user = useAuthStore((s) => s.user);
  const openThread = useChatStore((s) => s.openThread);

  const [property, setProperty] = useState<Property | null>(null);
  const [owner, setOwner] = useState<Profile | null>(null);
  const [active, setActive] = useState(0);
  const [preview, setPreview] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);

  const [docsAccess, setDocsAccess] = useState(false);
  const [docsReq, setDocsReq] = useState<PropertyRequest | null>(null);
  const [atsReq, setAtsReq] = useState<PropertyRequest | null>(null);
  const [atsAccess, setAtsAccess] = useState(false);
  const [modalKind, setModalKind] = useState<"documents" | "ats" | null>(null);
  const [showAts, setShowAts] = useState(false);

  const load = async () => {
    const p = await findVisiblePropertyById(id);
    setProperty(p ?? null);
    if (p) {
      setOwner((await findProfileById(p.ownerId)) ?? null);
      if (user) {
        setDocsAccess(await hasAccess(p.id, user.id, "documents"));
        setAtsAccess(await hasAccess(p.id, user.id, "ats"));
        setDocsReq((await getRequest(p.id, user.id, "documents")) ?? null);
        setAtsReq((await getRequest(p.id, user.id, "ats")) ?? null);
      }
    }
    setLoading(false);
  };
  useEffect(() => {
    load();
    const onFocus = () => load();
    window.addEventListener("focus", onFocus);
    return () => window.removeEventListener("focus", onFocus);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [id, user]);

  const dmOwner = async () => {
    if (!user || !owner) return;
    await openThread(user, owner);
    router.push(`/messages?to=${owner.id}`);
  };

  if (loading) return <Spinner />;
  if (!property)
    return (
      <div className="p-10 text-center text-slate-500">
        Listing not found.{" "}
        <Link href="/all-listings" className="text-primary hover:underline">Browse listings</Link>
      </div>
    );

  const isOwner = user?.id === property.ownerId;
  const canSeePrice = property.showPrice || isOwner;
  const canSeeDocs = property.showAttachments || isOwner || docsAccess;
  const hasDocs = property.attachments.length > 0;
  const ownerName = owner?.username ?? displayName(property.ownerEmail);

  const atsDoc = property.ats;
  const showAtsSection = !!atsDoc && (isOwner || property.atsVisibility !== "hidden");
  const atsOpen = property.atsVisibility === "document";
  const canSeeAts = !!atsDoc && (isOwner || atsOpen || atsAccess);
  const atsFilename = atsReq?.atsProvidedFilename ?? atsDoc?.filename;

  return (
    <div className="mx-auto max-w-5xl space-y-6 p-4 sm:p-6">
      <Link href="/all-listings" className="text-sm text-slate-500 hover:text-primary">← Back to listings</Link>

      <div className="overflow-hidden rounded-2xl border border-line bg-white">
        <div className="aspect-[16/9] bg-slate-100">
          {property.photos[active] ? (
            // eslint-disable-next-line @next/next/no-img-element
            <img src={property.photos[active]} alt={property.title} className="h-full w-full object-cover" />
          ) : (
            <div className="grid h-full place-items-center text-slate-300">No photos</div>
          )}
        </div>
        {property.photos.length > 1 && (
          <div className="flex gap-2 overflow-x-auto p-3">
            {property.photos.map((src, i) => (
              <button key={i} onClick={() => setActive(i)} className={`h-16 w-24 shrink-0 overflow-hidden rounded-lg border-2 ${i === active ? "border-primary" : "border-transparent"}`}>
                {/* eslint-disable-next-line @next/next/no-img-element */}
                <img src={src} alt="" loading="lazy" decoding="async" className="h-full w-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <div className="grid gap-6 lg:grid-cols-3">
        <div className="space-y-5 lg:col-span-2">
          <div>
            <div className="flex items-center gap-2">
              <Badge tone="blue">{property.type}</Badge>
              {isOwner && <Badge tone="green">Your listing</Badge>}
            </div>
            <h1 className="mt-2 text-2xl font-bold">{property.title}</h1>
            <p className="mt-1 text-slate-500">📍 {property.location}</p>
            <p className="mt-3 text-2xl font-bold text-ink">
              {canSeePrice ? formatPeso(property.price) : <span className="text-lg text-slate-400">Price on request</span>}
            </p>
            <p className="mt-1 text-xs text-slate-400">Listed {formatDate(property.createdAt)}</p>
          </div>

          <PropertyTags tags={property.tags} />

          <div>
            <h2 className="mb-1 font-semibold">Description</h2>
            <p className="whitespace-pre-line text-sm leading-relaxed text-slate-600">
              {property.description || "No description provided."}
            </p>
          </div>

          {/* Authority to Sell */}
          {showAtsSection && atsDoc && (
            <div className="rounded-2xl border border-line bg-white p-4">
              <div className="flex items-center justify-between">
                <h2 className="font-semibold">Authority to Sell (ATS)</h2>
                <Badge tone="green">Verified seller</Badge>
              </div>
              {canSeeAts ? (
                <button onClick={() => setShowAts(true)} className="mt-3 flex w-full items-center gap-2 rounded-lg border border-line bg-white px-3 py-2 text-sm text-slate-700 hover:border-primary">
                  📜 View ATS{atsFilename ? ` — ${atsFilename}` : ""}
                </button>
              ) : (
                <div className="mt-3 rounded-xl border border-dashed border-line bg-slate-50 p-4">
                  <p className="text-sm text-slate-600">🔒 The Authority to Sell is available <strong>on request</strong>.</p>
                  {property.requiresLOI && (
                    <p className="mt-1 text-sm text-amber-700">To see the ATS, please provide a <strong>Letter of Intent</strong>.</p>
                  )}
                  {atsReq?.status === "pending" ? (
                    <div className="mt-3 space-y-1">
                      <p className="rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-700">⏳ Please wait — your request was sent. The owner will provide the ATS.</p>
                      <Link href={`/my-listings?tab=requests&open=${atsReq.id}`} className="inline-block text-xs text-primary hover:underline">View your request →</Link>
                    </div>
                  ) : atsReq?.status === "denied" ? (
                    <div className="mt-3 space-y-1">
                      <button onClick={() => setModalKind("ats")} className="btn-outline">Request was declined — try again</button>
                      <Link href={`/my-listings?tab=requests&open=${atsReq.id}`} className="block text-xs text-primary hover:underline">View your request →</Link>
                    </div>
                  ) : (
                    <button onClick={() => setModalKind("ats")} className="btn-primary mt-3">Request ATS</button>
                  )}
                </div>
              )}
            </div>
          )}

          {/* Documents */}
          {hasDocs && (
            <div>
              <h2 className="mb-2 font-semibold">Documents ({property.attachments.length})</h2>
              {canSeeDocs ? (
                <ul className="space-y-2">
                  {property.attachments.map((a) => (
                    <li key={a.id}>
                      <button onClick={() => setPreview(a.url)} className="flex w-full items-center gap-2 rounded-lg border border-line bg-white px-3 py-2 text-sm text-slate-700 hover:border-primary">
                        📄 {a.filename}
                      </button>
                    </li>
                  ))}
                </ul>
              ) : (
                <div className="rounded-xl border border-dashed border-line bg-slate-50 p-4">
                  <p className="text-sm font-medium text-slate-700">🔒 Documents are private</p>
                  {docsReq?.status === "pending" ? (
                    <div className="mt-3 space-y-1">
                      <p className="rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-700">⏳ Please wait — the owner has been notified.</p>
                      <Link href={`/my-listings?tab=requests&open=${docsReq.id}`} className="inline-block text-xs text-primary hover:underline">View your request →</Link>
                    </div>
                  ) : docsReq?.status === "denied" ? (
                    <div className="mt-3 space-y-1">
                      <button onClick={() => setModalKind("documents")} className="btn-outline">Request was declined — try again</button>
                      <Link href={`/my-listings?tab=requests&open=${docsReq.id}`} className="block text-xs text-primary hover:underline">View your request →</Link>
                    </div>
                  ) : (
                    <button onClick={() => setModalKind("documents")} className="btn-primary mt-3">Request access</button>
                  )}
                </div>
              )}
            </div>
          )}

          <div className="h-64 overflow-hidden rounded-2xl border border-line">
            <PropertyMap properties={[property]} focusId={property.id} />
          </div>
        </div>

        <aside className="space-y-4">
          <div className="card p-5">
            <p className="text-sm font-semibold text-slate-700">Listed by</p>
            <div className="mt-3 flex items-center gap-3">
              <Avatar email={property.ownerEmail} size={44} />
              <div>
                <p className="font-medium text-ink">{ownerName}</p>
                <p className="text-xs text-slate-500">{property.ownerEmail}</p>
              </div>
            </div>
            {!isOwner && <button onClick={dmOwner} className="btn-primary mt-4 w-full">💬 Message owner</button>}
            {isOwner && <Link href="/my-listings?tab=requests" className="btn-outline mt-4 block w-full text-center">View requests</Link>}
          </div>
        </aside>
      </div>

      {preview && <AttachmentModal url={preview} onClose={() => setPreview(null)} />}
      {showAts && atsDoc && (
        <DocumentModal kind="ats" fromName={ownerName} filename={atsFilename} onClose={() => setShowAts(false)} />
      )}
      {modalKind && (
        <RequestModal
          property={property}
          kind={modalKind}
          requiresLOI={property.requiresLOI}
          onClose={() => setModalKind(null)}
          onDone={async () => {
            await load();
          }}
        />
      )}
    </div>
  );
}
