# ─── Neon Postgres ──────────────────────────────────────────────
# Create a project at https://neon.tech, then copy two connection strings
# from Project → Connection Details.

# POOLED connection (PgBouncer) — used by the app at runtime.
# In Neon: keep "Pooled connection" ON. Add the pgbouncer params shown below.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# DIRECT connection (non-pooled) — used ONLY by `prisma migrate`.
# In Neon: turn "Pooled connection" OFF to reveal the direct host (no "-pooler").
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ─── App data source ────────────────────────────────────────────
# "mock"   = in-memory demo data (default, no database needed)
# "prisma" = read/write the slice through the /api layer backed by Postgres
NEXT_PUBLIC_DATA_SOURCE="mock"
