// ─────────────────────────────────────────────────────────────
// Prisma schema — FUTURE backend (not wired up yet).
//
// Target data model for the PostgreSQL (NeonTech) backend. Maps 1:1
// to the TypeScript types in src/lib/types.ts and the mock data in
// src/lib/data. When the backend work starts:
//   1. set DATABASE_URL in .env
//   2. run `npx prisma migrate dev`
//   3. replace the bodies in src/lib/data/services.ts with Prisma
//      queries (signatures already match these models).
// ─────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel target is what Netlify's Lambda
  // functions run on, so the query engine is bundled for production too.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — app runtime
  directUrl = env("DIRECT_URL")   // direct — used by `prisma migrate`
}

enum Plan {
  basic
  premium
}

enum BillingInterval {
  monthly
  annual
}

enum PropertyType {
  Office
  Warehouse
  Agricultural
  MixedUse
  GasStation
  Retail
}

enum MessageContentType {
  text
  image
  attachment
}

enum PaymentStatus {
  pending
  approved
  rejected
}

model Profile {
  id                     String  @id @default(cuid())
  email                  String  @unique
  username               String
  plan                   Plan    @default(basic)
  isAdmin                Boolean @default(false)
  defaultShowPrice       Boolean @default(true)
  defaultShowAttachments Boolean @default(true)
  code                   String         @unique
  chatVisibility         ChatVisibility @default(everyone)
  allowFriendRequests    Boolean        @default(true)
  active                 Boolean        @default(true)
  planInterval           BillingInterval?
  planRenewsAt           DateTime?
  lastActiveAt           DateTime         @default(now())
  verified               Boolean          @default(false)
  company                String?
  licenseNo              String?

  properties     Property[]
  messages       Message[]
  worldMessages  WorldMessage[]
  memberships    GroupMember[]
  payments       Payment[]
  invoices       Invoice[]
  tickets        SupportTicket[]
  aiRequests     AiRequest[]
  createdGroups  ChatGroup[]      @relation("GroupCreator")
  threadsA       DirectThread[]   @relation("ThreadParticipantA")
  threadsB       DirectThread[]   @relation("ThreadParticipantB")
  directMessages DirectMessage[]
  leads          Lead[]
  favorites      Favorite[]
  savedSearches  SavedSearch[]

  createdAt DateTime @default(now())
}

model Property {
  id              String       @id @default(cuid())
  owner           Profile      @relation(fields: [ownerId], references: [id])
  ownerId         String
  ownerEmail      String
  title           String
  description     String
  price           BigInt
  location        String
  latitude        Float
  longitude       Float
  type            PropertyType
  tags            String[]
  photos          String[]
  showPrice       Boolean      @default(true)
  showAttachments Boolean      @default(true)
  atsUrl          String?
  atsFilename     String?
  atsVisibility   AtsVisibility @default(hidden)
  requiresLOI     Boolean      @default(false)
  views           Int          @default(0)
  videoUrl        String?
  tourUrl         String?
  floorPlans      String[]
  createdAt       DateTime     @default(now())

  attachments    PropertyAttachment[]
  requests       PropertyRequest[]
  leads          Lead[]
  favoritedBy    Favorite[]
  viewings       Viewing[]

  @@index([ownerId])
  @@index([location])
}

model PropertyAttachment {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  url        String
  filename   String
}

model ChatGroup {
  id             String   @id @default(cuid())
  name           String
  createdBy      Profile  @relation("GroupCreator", fields: [createdByEmail], references: [email])
  createdByEmail String
  createdAt      DateTime @default(now())

  members  GroupMember[]
  messages Message[]
}

model GroupMember {
  group   ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String
  member  Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String

  @@id([groupId, userId])
}

model Message {
  id          String             @id @default(cuid())
  group       ChatGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  author      Profile            @relation(fields: [userId], references: [id])
  userId      String
  userEmail   String
  content     String
  contentType MessageContentType @default(text)
  filename    String?
  replyToId      String?
  replyToAuthor  String?
  replyToPreview String?
  editedAt       DateTime?
  deleted        Boolean            @default(false)
  createdAt   DateTime           @default(now())

  @@index([groupId])
}

model WorldMessage {
  id          String             @id @default(cuid())
  author      Profile            @relation(fields: [userId], references: [id])
  userId      String
  userEmail   String
  content     String
  contentType MessageContentType @default(text)
  filename    String?
  replyToId      String?
  replyToAuthor  String?
  replyToPreview String?
  editedAt       DateTime?
  deleted        Boolean            @default(false)
  createdAt   DateTime           @default(now())

  @@index([createdAt])
}

model DirectThread {
  id        String   @id @default(cuid())
  userA     Profile  @relation("ThreadParticipantA", fields: [userAId], references: [id])
  userAId   String
  userB     Profile  @relation("ThreadParticipantB", fields: [userBId], references: [id])
  userBId   String
  createdAt DateTime @default(now())

  messages DirectMessage[]

  @@unique([userAId, userBId])
}

model DirectMessage {
  id          String             @id @default(cuid())
  thread      DirectThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId    String
  sender      Profile            @relation(fields: [senderId], references: [id])
  senderId    String
  senderEmail String
  content     String
  contentType MessageContentType @default(text)
  filename    String?
  replyToId      String?
  replyToAuthor  String?
  replyToPreview String?
  editedAt       DateTime?
  deleted        Boolean            @default(false)
  createdAt   DateTime           @default(now())

  @@index([threadId])
}

model ChatPresence {
  userId     String   @id
  email      String
  lastSeenAt DateTime @default(now())
}

model ChatTyping {
  conversationId String
  userId         String
  email          String
  updatedAt      DateTime @default(now())

  @@id([conversationId, userId])
  @@index([conversationId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  userEmail String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageRead {
  userId         String
  conversationId String
  lastReadAt     DateTime @default(now())

  @@id([userId, conversationId])
}

model TeaserDraft {
  id        String   @id @default(cuid())
  userId    String
  title     String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TeaserUsage {
  userId    String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String          @id @default(cuid())
  user          Profile         @relation(fields: [userId], references: [id])
  userId        String
  plan          Plan
  interval      BillingInterval
  reference     String
  attachmentUrl String?         // proof-of-payment screenshot
  status        PaymentStatus   @default(pending)
  createdAt     DateTime        @default(now())
  periodStart   DateTime?
  periodEnd     DateTime?       // = due date (last day of the month)
  reviewedAt    DateTime?
  reviewedBy    String?
  invoice       Invoice?
}

enum InvoiceStatus {
  paid
  void
}

model Invoice {
  id          String          @id @default(cuid())
  number      String          @unique
  user        Profile         @relation(fields: [userId], references: [id])
  userId      String
  userEmail   String
  plan        Plan
  interval    BillingInterval
  amount      Int             // PHP
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  status      InvoiceStatus   @default(paid)
  payment     Payment?        @relation(fields: [paymentId], references: [id])
  paymentId   String?         @unique
  proofUrl    String?
  reference   String?
  issuedAt    DateTime        @default(now())
  issuedBy    String?

  @@index([userId])
}

enum TicketStatus {
  open
  resolved
}

enum TicketCategory {
  Login
  Listing
  Payment
  Account
  Bug
  Other
}

model SupportTicket {
  id        String         @id @default(cuid())
  number    String         @unique
  user      Profile        @relation(fields: [userId], references: [id])
  userId    String
  userEmail String
  plan      Plan
  priority  Boolean        @default(false)
  category  TicketCategory
  subject   String
  message   String
  status    TicketStatus   @default(open)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  replies   TicketReply[]

  @@index([userId])
  @@index([status])
}

model TicketReply {
  id        String        @id @default(cuid())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  fromEmail String
  isAdmin   Boolean
  body      String
  createdAt DateTime      @default(now())
}

enum AiToolType {
  analysis
  comparison
}

enum AiRequestStatus {
  pending
  completed
  rejected
}

model AiRequest {
  id              String          @id @default(cuid())
  number          String          @unique
  user            Profile         @relation(fields: [userId], references: [id])
  userId          String
  userEmail       String
  type            AiToolType
  price           Int             // PHP
  description     String
  documents       Json            // [{ filename, url }]
  proofUrl        String?
  status          AiRequestStatus @default(pending)
  adminNotes      String?
  resultDocuments Json            @default("[]")
  reviewedBy      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model AppSetting {
  key   String @id
  value String
}

// ─── Added: attachment access requests + notifications ──────────

enum RequestStatus {
  pending
  approved
  denied
}

enum NotificationType {
  request_new
  request_approved
  request_denied
  request_message
  friend_request
  friend_accepted
  payment_submitted
  invoice_issued
  billing_warning
  ticket_update
  ai_update
  admin_notice
}

enum AtsVisibility {
  hidden
  on_request
  document
}

enum RequestKind {
  documents
  ats
}

model PropertyRequest {
  id            String        @id @default(cuid())
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId    String
  propertyTitle String
  kind          RequestKind
  requesterId   String
  requesterName String
  requesterEmail String
  requesterCode String
  ownerId       String
  ownerEmail    String
  message       String
  loiFilename   String?
  atsProvidedFilename String?
  status        RequestStatus @default(pending)
  leadId        String?
  createdAt     DateTime      @default(now())

  messages RequestMessage[]

  @@unique([propertyId, requesterId, kind])
  @@index([ownerId])
}

model RequestMessage {
  id          String             @id @default(cuid())
  request     PropertyRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId   String
  senderId    String
  senderEmail String
  content     String
  contentType MessageContentType @default(text)
  filename    String?
  createdAt   DateTime           @default(now())

  @@index([requestId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  requestId String?
  requestKind RequestKind?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

// ─── Added: chat privacy + friend requests ──────────────────────

enum ChatVisibility {
  everyone
  invite_only
  hidden
}

enum FriendStatus {
  pending
  accepted
  declined
}

model FriendRequest {
  id        String       @id @default(cuid())
  fromId    String
  fromEmail String
  toId      String
  toEmail   String
  status    FriendStatus @default(pending)
  createdAt DateTime     @default(now())

  @@unique([fromId, toId])
  @@index([toId])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  target     String
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ─── Leads Board (sales pipeline) ──────────────────────────────
enum LeadStatus {
  open
  won
  lost
}

model LeadStage {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  sortOrder   Int
  probability Int     @default(100)
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)

  leads Lead[]
}

model LeadSource {
  id   String @id @default(cuid())
  name String

  leads Lead[]
}

model LeadType {
  id   String @id @default(cuid())
  name String

  leads Lead[]
}

model Lead {
  id                String     @id @default(cuid())
  owner             Profile    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId           String
  ownerEmail        String
  title             String
  description       String     @default("")
  value             BigInt     @default(0)
  contactName       String
  contactEmail      String     @default("")
  contactPhone      String     @default("")
  property          Property?  @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId        String?
  propertyTitle     String?
  source            LeadSource @relation(fields: [sourceId], references: [id])
  sourceId          String
  type              LeadType   @relation(fields: [typeId], references: [id])
  typeId            String
  stage             LeadStage  @relation(fields: [stageId], references: [id])
  stageId           String
  status            LeadStatus @default(open)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  activities        LeadActivity[]

  @@index([ownerId])
  @@index([stageId])
}

// ─── Favorites / saved listings ────────────────────────────────
model Favorite {
  id         String   @id @default(cuid())
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
}

// ─── Saved searches (filter sets + new-listing alerts) ─────────
model SavedSearch {
  id           String   @id @default(cuid())
  user         Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  name         String
  filters      Json
  notify       Boolean  @default(true)
  createdAt    DateTime @default(now())
  lastViewedAt DateTime @default(now())

  @@index([userId])
}

// ─── Schedule a viewing ────────────────────────────────────────
enum ViewingStatus {
  requested
  confirmed
  declined
  cancelled
}

model Viewing {
  id             String        @id @default(cuid())
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId     String
  propertyTitle  String
  requesterId    String
  requesterName  String
  requesterEmail String
  ownerId        String
  ownerEmail     String
  preferredAt    DateTime
  message        String        @default("")
  status         ViewingStatus @default(requested)
  confirmedAt    DateTime?
  ownerNote      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ownerId])
  @@index([requesterId])
}

// ─── Agent reviews & ratings ───────────────────────────────────
model Review {
  id            String   @id @default(cuid())
  brokerId      String
  brokerEmail   String
  reviewerId    String
  reviewerName  String
  reviewerEmail String
  communication Int
  knowledge     Int
  honesty       Int
  overall       Float
  comment       String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([brokerId, reviewerId])
  @@index([brokerId])
}

// ─── Lead activities & follow-up reminders ─────────────────────
enum LeadActivityType {
  call
  email
  meeting
  note
  task
}

model LeadActivity {
  id        String           @id @default(cuid())
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  type      LeadActivityType
  note      String           @default("")
  dueAt     DateTime?
  done      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([leadId])
}
